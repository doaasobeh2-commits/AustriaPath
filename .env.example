# =============================================================================
# AustriaPath — Environment Variables
# =============================================================================
# Copy to .env for local dev. Set in Vercel Project Settings for production.
# NEVER commit .env to git.
# =============================================================================

# --- Client (embedded in browser bundle — NOT secrets) -----------------------
# WARNING: VITE_* variables are visible in production JavaScript.

# Admin email identity (public). Used for role detection only.
VITE_ADMIN_EMAIL=fadisobehau@gmail.com

# TEMPORARY closed-beta bootstrap ONLY. Leave EMPTY in production.
# Creates in-memory admin seed on first login when non-empty.
# MUST move to backend before public launch. See Backend Security Requirements.md.
VITE_ADMIN_INITIAL_PASSWORD=

# --- Server (Vercel serverless — never expose to client) ---------------------

# Required for /api/ai/openai
OPENAI_API_KEY=

# Optional override (default: gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini

# Optional — enable when backend API is running (npm run server:dev)
# VITE_USE_BACKEND=true
# VITE_API_BASE=/v1
# DATABASE_URL=postgresql://austria:austria@localhost:5432/austria_path
# SESSION_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
# EMAIL_FROM=AustriaPath <noreply@austriapath.at>
# SENTRY_DSN=
# ADMIN_BOOTSTRAP_SECRET=
