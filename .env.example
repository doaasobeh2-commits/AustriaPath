# Admin identity (optional override; defaults to configured production admin email)
VITE_ADMIN_EMAIL=fadisobehau@gmail.com

# Initial admin password used ONLY when seeding a fresh install with no admin in localStorage.
# Set locally in .env — never commit .env to git.
# Existing browsers with admin already in austriaPathUsers are unaffected.
VITE_ADMIN_INITIAL_PASSWORD=
