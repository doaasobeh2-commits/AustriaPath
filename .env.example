# Admin identity (optional override; defaults to configured production admin email)
# WARNING: VITE_* variables are embedded in the browser bundle. Do not treat them as secrets.
VITE_ADMIN_EMAIL=fadisobehau@gmail.com

# TEMPORARY client-side bootstrap only — remove before production launch.
# Admin seeding MUST move to the backend (see Backend Security Requirements.md).
# Never commit .env to git.
VITE_ADMIN_INITIAL_PASSWORD=
