{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "caches": {
    "npm": {
      "directory": "/tmp/.npm",
      "type": "shared"
    }
  },
  "steps": {
    "install": {
      "caches": ["npm"]
    },
    "build": {
      "caches": [],
      "commands": ["npm run build"]
    }
  },
  "deploy": {
    "startCommand": "npm run server:migrate && npm run server:start"
  }
}
