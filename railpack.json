{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "caches": {
    "npm": {
      "directory": "/tmp/.npm",
      "type": "shared"
    }
  },
  "steps": {
    "install": {
      "caches": ["npm"],
      "commands": [
        "RAILPACK_DISABLE_CACHES=node-modules npm ci --cache /tmp/.npm --no-audit --fund=false"
      ]
    },
    "build": {
      "caches": [],
      "commands": []
    }
  },
  "deploy": {
    "startCommand": "npm run server:migrate && npm run server:start"
  }
}
